<mapper namespace="org.handy.handyvue.mapper.CmMenuMstMapper">

    <resultMap id="menuTreeResultMap" type="org.handy.handyvue.dto.CmMenuMstDto">
        <id property="vMenuId" column="v_menu_id" />
        <result property="vMenuNm" column="v_menu_nm" />
        <result property="isOpen" column="is_open" />

        <collection property="children" ofType="org.handy.handyvue.dto.CmMenuMstDto"
                    select="selectSubMenuList" column="v_menu_id" />
    </resultMap>

