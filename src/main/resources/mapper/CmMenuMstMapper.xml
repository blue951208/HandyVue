    <select id="selectCmMenuList" resultMap="menuTreeResultMap">
        SELECT *, false as is_open
        FROM cm_menu_mst
        WHERE n_level = 1 AND v_use_yn = 'Y' AND v_flag_del = 'N'
        ORDER BY n_sort
    </select>

    <select id="selectSubMenuList" resultMap="menuTreeResultMap">
        SELECT *
        FROM cm_menu_mst
        WHERE v_parent_menu_id = #{v_menu_id} AND v_use_yn = 'Y' AND v_flag_del = 'N'
        ORDER BY n_sort
    </select>

</mapper>